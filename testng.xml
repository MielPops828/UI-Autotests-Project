<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full Test Suite" parallel="tests" thread-count="3">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="utils.TestListener"/>
        <listener class-name="utils.RetryListener"/>
    </listeners>
    <test name="Home tests">
        <parameter name="suiteName" value="home"/>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.HomePageLoadTest"/>
            <class name="tests.NavigationMenuTransitionTest"/>
            <class name="tests.StickyHeaderTest"/>
        </classes>
    </test>
    <test name="Login tests">
        <parameter name="suiteName" value="login"/>
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.LoginPageLoadTest"/>
            <class name="tests.ValidAuthTest"/>
            <class name="tests.InvalidAuthTest"/>
            <class name="tests.SuccessLogoutTest"/>
        </classes>
    </test>
    <test name="SQL tests">
        <parameter name="suiteName" value="sql"/>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.SQLEXCookieTest"/>
            <class name="tests.SQLEXScrollFocusTest"/>
        </classes>
    </test>
    <test name="Drag n Drop tests">
        <parameter name="suiteName" value="drag n drop"/>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.DragAndDropTest"/>
        </classes>
    </test>
</suite>